#compdef cento

_cento_tool_ids() {
  command cento tools 2>/dev/null | awk '{print $1}'
}

_cento_alias_ids() {
  command cento aliases 2>/dev/null | awk '{print $1}'
}

_cento_first_level() {
  local -a builtins tools aliases
  builtins=(
    'help:Show cento help'
    'tools:List registered cento tools'
    'platforms:List tool platform support'
    'aliases:List configured cento aliases'
    'conf:Open or print cento config'
    'completion:Print shell completion'
    'install:Install shell and tmux integration'
    'run:Run a registered tool by id'
  )
  tools=(${(@f)$(_cento_tool_ids)})
  aliases=(${(@f)$(_cento_alias_ids)})

  _describe -t cento-builtins 'cento built-ins' builtins
  (( ${#tools[@]} )) && _describe -t cento-tools 'cento tools' tools
  (( ${#aliases[@]} )) && _describe -t cento-aliases 'cento aliases' aliases
}

_cento() {
  local curcontext="$curcontext" state
  typeset -A opt_args

  _arguments -C \
    '1:command:->command' \
    '*::arg:->args'

  case $state in
    command)
      _cento_first_level
      return
      ;;
    args)
      local subcmd=${words[2]:-}
      case "$subcmd" in
        conf)
          _arguments '--path[Print the cento config path]'
          ;;
        completion)
          _values 'shell' zsh
          ;;
        platforms)
          _values 'platform' linux macos --markdown
          ;;
        install)
          _values 'target' all zsh tmux
          ;;
        run)
          if (( CURRENT == 3 )); then
            local -a tools
            tools=(${(@f)$(_cento_tool_ids)})
            _describe -t cento-tools 'cento tools' tools
          fi
          ;;
        burp)
          if (( CURRENT == 3 )); then
            _values 'burp command' \
              'download[Download latest official artifact]' \
              'setup[Install JAR launcher]' \
              'controller[Control background Burp process]' \
              'start[Start Burp in background]' \
              'run[Run Burp in foreground]' \
              'stop[Stop background Burp process]' \
              'restart[Restart background Burp process]' \
              'status[Show setup and process status]' \
              'logs[Print or follow controller log]' \
              'paths[Print managed paths]' \
              'docs[Print Burp wrapper docs]'
          else
            case "${words[3]:-}" in
              download|setup)
                _arguments \
                  '--type[Artifact type]:type:(jar linux)' \
                  '--force[Replace existing local files]' \
                  '--output-dir[Download directory]:directory:_files -/' \
                  '--install-dir[Install directory]:directory:_files -/' \
                  '--bin-dir[Launcher directory]:directory:_files -/'
                ;;
              controller|start|run|restart)
                _arguments \
                  '--project-file[Burp project file]:file:_files' \
                  '--config-file[Burp config file]:file:_files' \
                  '--use-defaults[Skip initial prompts where supported]' \
                  '--java-opts[Extra JVM options]:options:'
                ;;
              logs)
                _arguments '(-f --follow)'{-f,--follow}'[Follow log output]'
                ;;
            esac
          fi
          ;;
        bridge)
          if (( CURRENT == 3 )); then
            _values 'bridge command' \
              'start[Start background reverse SSH tunnel]' \
              'foreground[Run reverse SSH tunnel in foreground]' \
              'stop[Stop background tunnel]' \
              'restart[Restart background tunnel]' \
              'status[Show bridge status]' \
              'check[Validate local and remote bridge context]' \
              'expose-linux[Expose this Linux node as a VM Unix socket]' \
              'install-linux-service[Keep the Linux bridge socket repaired with a user service]' \
              'install-mac-service[Keep the Mac bridge socket repaired with launchd]' \
              'expose-mac[Expose this Mac node as a VM Unix socket]' \
              'to-linux[Open a shell on the Linux node via VM Unix socket]' \
              'to-mac[Open a shell on the Mac node via VM Unix socket]' \
              'context-linux[Print Linux node gather-context via VM Unix socket]' \
              'context-mac[Print Mac node gather-context via VM Unix socket]' \
              'mesh-status[Show VM-side Cento Unix sockets]' \
              'from-mac[Run a command on the Linux node through the VM]' \
              'command[Print local tunnel command]' \
              'mac-command[Print Mac connection command]' \
              'docs[Print bridge notes]'
          else
            _arguments \
              '--vm-host[OCI VM public IP or hostname]:host:' \
              '--vm-user[OCI VM SSH user]:user:' \
              '--identity[OCI VM private key]:file:_files' \
              '--remote-port[VM-side tunnel port]:port:' \
              '--remote-bind[VM-side bind address]:address:' \
              '--local-host[Local target address]:address:' \
              '--local-port[Local target port]:port:' \
              '--local-user[Local SSH user for Mac command]:user:' \
              '--public[Bind the VM-side tunnel to 0.0.0.0]'
          fi
          ;;
        cluster)
          if (( CURRENT == 3 )); then
            _values 'cluster command' \
              'init[Write node and cluster config]' \
              'nodes[List cluster nodes]' \
              'status[Show cluster status]' \
              'activity[Show workstation activity from tmux panes and agents]' \
              'exec[Run a command on a node]' \
              'sync[Show git drift across nodes]' \
              'heal[Repair bridge services]' \
              'companion-setup[Print companion installer script]' \
              'heartbeat[Show companion heartbeat state]' \
              'metric[Print cluster metrics]' \
              'ask[Execute a small natural-language cluster request]'
          elif (( CURRENT == 4 )) && [[ "${words[3]:-}" == "activity" ]]; then
            _values 'activity option or node' --json linux macos all
          elif (( CURRENT == 4 )) && [[ "${words[3]:-}" == "activity" || "${words[3]:-}" == "exec" || "${words[3]:-}" == "heal" || "${words[3]:-}" == "heartbeat" ]]; then
            _values 'node' linux macos iphone all
          elif (( CURRENT == 4 )) && [[ "${words[3]:-}" == "companion-setup" ]]; then
            _values 'companion' iphone
          fi
          ;;
        mobile)
          if (( CURRENT == 3 )); then
            _values 'mobile command' \
              'e2e[Run native iOS mobile e2e validation]' \
              'token-from-linux[Print the Linux mobile gateway token]' \
              'watch-status[Report Apple Watch physical/simulator readiness]' \
              'docs[Show mobile command help]'
          fi
          ;;
        incident)
          if (( CURRENT == 3 )); then
            _values 'incident command' \
              'check[Run an incident check]' \
              'status[Show incident guardrail state]' \
              'install[Install scheduled incident check]' \
              'uninstall[Uninstall scheduled incident check]' \
              'docs[Show incident docs]'
          elif (( CURRENT == 4 )) && [[ "${words[3]:-}" == "check" || "${words[3]:-}" == "install" || "${words[3]:-}" == "uninstall" ]]; then
            _values 'incident key' iphone-ce
          fi
          ;;
        agent-work)
          if (( CURRENT == 3 )); then
            _values 'agent-work command' \
              'bootstrap[Create Redmine project/status/tracker fields]' \
              'create[Create one agent task]' \
              'split[Create an agent work package]' \
              'list[List agent work items]' \
              'show[Show one issue]' \
              'claim[Claim an issue for an agent]' \
              'update[Update issue status and notes]' \
              'validate[Record validator result]' \
              'handoff[Write builder report and move to Validating]' \
              'validate-run[Run validation manifest checks]' \
              'prompt[Print or write an agent prompt]' \
              'dispatch[Dispatch an issue through the cluster]'
          fi
          ;;
        notify)
          if (( CURRENT == 3 )); then
            _values 'notify command or target' \
              'setup[Save ntfy topic for a target]' \
              'status[Show configured notification targets]' \
              'send[Send message to a target]' \
              'test[Send a test notification]' \
              'all[Send message to all targets]' \
              'iphone[Send message to iPhone target]'
          elif (( CURRENT == 4 )) && [[ "${words[3]:-}" == "send" || "${words[3]:-}" == "test" || "${words[3]:-}" == "setup" ]]; then
            _values 'target' iphone all
          fi
          ;;
      esac
      ;;
  esac
}

compdef _cento cento
