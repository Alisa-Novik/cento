{
  "run_dir": "workspace/runs/agent-work/28",
  "report": "workspace/runs/agent-work/28/validation-report.md",
  "requires": {
    "builder_report": "workspace/runs/agent-work/28/builder-report.md",
    "ui_screenshots": true,
    "validator_agents": [
      "alice-validator"
    ]
  },
  "checks": [
    {
      "name": "agent_work syntax",
      "type": "command",
      "command": "python3 -m py_compile scripts/agent_work.py scripts/deliverables_hub.py",
      "timeout_seconds": 30
    },
    {
      "name": "agent_work validate-run help",
      "type": "command",
      "command": "python3 scripts/agent_work.py validate-run --help | rg \"validation.json|Validator\"",
      "timeout_seconds": 30
    },
    {
      "name": "agent_work handoff help",
      "type": "command",
      "command": "python3 scripts/agent_work.py handoff --help | rg \"Builder report|Validating\"",
      "timeout_seconds": 30
    },
    {
      "name": "deliverables hub link validation",
      "type": "command",
      "command": "python3 scripts/deliverables_hub.py workspace/runs/agent-work/18/deliverables.json --check-links --check-only",
      "timeout_seconds": 30
    },
    {
      "name": "validator lane documentation exists",
      "type": "file",
      "path": "docs/agent-work-validator-lane.md",
      "non_empty": true
    },
    {
      "name": "deliverables hub manifest exists",
      "type": "file",
      "path": "workspace/runs/agent-work/18/deliverables.json",
      "non_empty": true
    },
    {
      "name": "desktop deliverables hub screenshot",
      "type": "screenshot",
      "url": "file:///{root}/workspace/runs/agent-work/18/start-here.html",
      "output": "workspace/runs/agent-work/28/screenshots/start-here.png",
      "viewport": "1280,1200",
      "wait_ms": 1000,
      "timeout_seconds": 60
    },
    {
      "name": "mobile deliverables hub screenshot",
      "type": "screenshot",
      "url": "file:///{root}/workspace/runs/agent-work/18/start-here.html",
      "output": "workspace/runs/agent-work/28/screenshots/mobile-start-here.png",
      "viewport": "390,844",
      "wait_ms": 1000,
      "timeout_seconds": 60
    }
  ]
}
